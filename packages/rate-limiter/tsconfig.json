{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@rateforge/types": [
        "../types/src/index.ts"
      ],
      "@rateforge/types/*": [
        "../types/src/*"
      ],
      "@rateforge/config": [
        "../config/src/index.ts"
      ],
      "@rateforge/config/*": [
        "../config/src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "references": [
    {
      "path": "../types"
    },
    {
      "path": "../config"
    }
  ]
}