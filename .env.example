# ------------------------------------------
# 1. GLOBAL & SHARED CONFIGURATION
# ------------------------------------------
# Node environment: development | test | production
NODE_ENV=development

# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info

# JWT secret used for signing and verifying internal requests.
# MUST BE IDENTICAL in both api-gateway and rate-limiter environments.
JWT_SECRET=super_secret_jwt_string_change_me_in_production

# Optional webhook used by the alert evaluator.
# Leave blank to keep alerts local in service logs only.
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXXXXX/BXXXXXXXXX/replace-with-real-webhook

# ------------------------------------------
# 2. API GATEWAY CONFIGURATION
# ------------------------------------------
# Default HTTP port for the API gateway.
PORT=3000

# The URL of your downstream application that RateForge is protecting.
DOWNSTREAM_TARGET_URL=http://localhost:8080

# Internal URL used by the API gateway to reach the rate-limiter service.
RATE_LIMITER_URL=http://localhost:3001

# The exact origin of your deployed dashboard (used for CORS validation).
FRONTEND_URL=http://localhost:5173

# Enterprise admin passphrase used to mint gateway admin JWTs via /api/v1/admin/login.
ADMIN_PASSPHRASE=change_me_to_a_strong_admin_passphrase

# ------------------------------------------
# 3. RATE LIMITER CONFIGURATION
# ------------------------------------------
# Port for the internal rate-limiter service.
PORT=3001

# Redis connection URL used by the rate-limiter.
REDIS_URL=redis://localhost:6379

# ------------------------------------------
# 4. DASHBOARD CONFIGURATION (Build-time)
# ------------------------------------------
# Dashboard build-time API base URL for browser requests.
VITE_GATEWAY_URL=http://localhost:3000
