# Core service configuration
# Redis connection URL used by the rate-limiter and other services.
REDIS_URL=redis://localhost:6379

# Default HTTP port for the API gateway (can be overridden per service).
PORT=3000

# Node environment: development | test | production
NODE_ENV=development

# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info

# JWT secret used for signing and verifying tokens.
# Change this value in your real .env files for each environment.
JWT_SECRET=change-me-in-production

