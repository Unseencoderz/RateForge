# Core service configuration
# Redis connection URL used by the rate-limiter and other services.
REDIS_URL=redis://localhost:6379

# Internal URL used by the API gateway to reach the rate-limiter service.
# In local development this is usually the local rate-limiter process on port 3001.
RATE_LIMITER_URL=http://localhost:3001

# Default HTTP port for the API gateway (can be overridden per service).
PORT=3000

# Node environment: development | test | production
NODE_ENV=production

# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info

# JWT secret used for signing and verifying tokens.
# Change this value in your real .env files for each environment.
JWT_SECRET=change-me-in-production-in-production

# Dashboard build-time API base URL for browser requests.
# Set this in the dashboard service environment before running the Vite build.
VITE_GATEWAY_URL=http://localhost:3000

